{
  "name": "@ojfbot/frame-ui-components",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./styles/dashboard": "./src/styles/Dashboard.css",
    "./styles/badge-button": "./src/styles/BadgeButton.css",
    "./styles/markdown-message": "./src/styles/MarkdownMessage.css"
  },
  "scripts": {
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "type-check": "tsc --noEmit",
    "test:visual": "test-storybook --url http://127.0.0.1:6006 --browsers chromium",
    "test:visual:update": "UPDATE_BASELINES=true pnpm test:visual",
    "test:visual:ci": "concurrently -k -s first -n 'SB,TEST' 'pnpm storybook --no-open -p 6006' 'wait-on tcp:6006 && pnpm test:visual'"
  },
  "peerDependencies": {
    "@carbon/react": ">=1",
    "react": ">=18",
    "react-dom": ">=18",
    "react-markdown": ">=9",
    "remark-gfm": ">=4"
  },
  "devDependencies": {
    "@carbon/react": "^1.71.0",
    "@carbon/styles": "^1.102.0",
    "storybook": "~8.4.0",
    "@storybook/react": "~8.4.0",
    "@storybook/react-vite": "~8.4.0",
    "@storybook/addon-essentials": "~8.4.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@storybook/test-runner": "~8.4.0",
    "playwright": "^1.40.0",
    "jest-image-snapshot": "^6.4.0",
    "@types/jest-image-snapshot": "^6.4.0",
    "wait-on": "^7.2.0",
    "concurrently": "^9.1.0"
  }
}
