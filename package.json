{
  "name": "@ojfbot/frame-ui-components",
  "version": "0.1.0",
  "private": false,
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "source": "./src/index.ts"
    },
    "./tokens": {
      "types": "./src/tokens.ts",
      "import": "./dist/tokens.js",
      "source": "./src/tokens.ts"
    },
    "./styles/tokens": "./src/styles/tokens.css",
    "./styles/dashboard": "./src/styles/Dashboard.css",
    "./styles/dashboard-layout": "./src/styles/DashboardLayout.css",
    "./styles/badge-button": "./src/styles/BadgeButton.css",
    "./styles/markdown-message": "./src/styles/MarkdownMessage.css",
    "./styles/thread-sidebar": "./src/styles/ThreadSidebar.css",
    "./styles/chat-shell": "./src/styles/ChatShell.css"
  },
  "typesVersions": {
    "*": {
      ".": ["src/index.ts"],
      "tokens": ["src/tokens.ts"]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "type-check": "tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "size": "node scripts/component-sizes.js",
    "size-limit": "size-limit",
    "visual-regression": "pnpm build-storybook && playwright test",
    "visual-regression:update": "pnpm build-storybook && playwright test --update-snapshots"
  },
  "peerDependencies": {
    "@carbon/react": ">=1",
    "@carbon/styles": ">=1",
    "react": ">=18",
    "react-dom": ">=18",
    "react-markdown": ">=9",
    "remark-gfm": ">=4"
  },
  "size-limit": [
    {
      "path": "src/components/*.tsx",
      "limit": "10 KB",
      "name": "Components (source)"
    },
    {
      "path": "src/styles/*.css",
      "limit": "25 KB",
      "name": "Styles (source)"
    }
  ],
  "devDependencies": {
    "@carbon/react": "^1.71.0",
    "@carbon/styles": "^1.102.0",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.0.1",
    "@storybook/addon-essentials": "~8.4.0",
    "@storybook/react": "~8.4.0",
    "@storybook/react-vite": "~8.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.0.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "size-limit": "^12.0.1",
    "storybook": "~8.4.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^3.1.0"
  }
}
